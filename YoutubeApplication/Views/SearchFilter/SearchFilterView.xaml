<UserControl
    x:Class="YoutubeApplication.Views.SearchFilter.SearchFilterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:YoutubeApplication.Views.SearchFilter"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:segmented="clr-namespace:YoutubeApplication.Components.SegmentedComponent"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>

                <segmented:SegmentedView
                    Title="類型"
                    Grid.Column="0"
                    Option="{Binding SelectedType}"
                    Options="{Binding TypeOptions}" />

                <segmented:SegmentedView
                    Title="片長"
                    Grid.Column="1"
                    Option="{Binding SelectedDuration}"
                    Options="{Binding DurationOptions}" />

                <segmented:SegmentedView
                    Title="上傳日期"
                    Grid.Column="2"
                    Option="{Binding SelectedDate}"
                    Options="{Binding DateOptions}" />

                <segmented:SegmentedView
                    Title="優先順序"
                    Grid.Column="3"
                    Option="{Binding SelectedOrder}"
                    Options="{Binding OrderOptions}" />
            </Grid>

            <StackPanel
                Grid.Row="1"
                Margin="0,32,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    Margin="0,0,8,0"
                    Command="{Binding OnCloseCommand}"
                    Content="取消"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Style="{StaticResource MaterialDesignFlatButton}" />

                <Button
                    Command="{Binding OnSubmitCommand}"
                    Content="套用"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>

</UserControl>
