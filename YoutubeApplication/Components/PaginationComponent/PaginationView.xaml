                  Stroke="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  StrokeThickness="1.5"
                  VerticalAlignment="Center" />
        </Button>

        <ComboBox Grid.Column="3"
                  Width="80"
                  Height="32"
                  Margin="16,0,0,0"
                  VerticalContentAlignment="Center"
                  ItemsSource="{Binding PageSizes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedItem="{Binding PageSize, RelativeSource={RelativeSource AncestorType=UserControl}}">

            <i:Interaction.Triggers>
