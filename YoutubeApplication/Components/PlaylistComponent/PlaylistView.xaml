<UserControl
    x:Class="YoutubeApplication.Components.PlaylistComponent.PlaylistView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:YoutubeApplication.Components.PlaylistComponent"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid x:Name="Root" Margin="10,5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="50" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Column="0"
            Width="80"
            Height="50"
            HorizontalAlignment="Left"
            VerticalAlignment="Center">
            <Border
                Width="45"
                Height="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#615B55"
                CornerRadius="3,3,0,0" />

            <Border
                Margin="0,4,0,0"
                Background="#333333"
                ClipToBounds="True"
                CornerRadius="8">
                <Image Source="{Binding PlaylistItem.ImgUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}" />
            </Border>

        </Grid>

        <StackPanel
            Grid.Column="1"
            Margin="10,0,0,0"
            VerticalAlignment="Center">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="White"
                Text="{Binding PlaylistItem.Title}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <ToggleButton
            Grid.Column="2"
            Background="Transparent"
            BorderThickness="0"
            Command="{Binding ClickCmd}"
            Cursor="Hand"
            IsChecked="{Binding PlaylistItem.IsSelected}">

            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent">
                        <Path
                            x:Name="BookmarkIcon"
                            Width="16"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M5,5 L15,5 L15,21 L10,17 L5,21 Z"
                            Fill="Transparent"
                            Stretch="Fill"
                            Stroke="White"
                            StrokeThickness="2" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="BookmarkIcon" Property="Fill" Value="White" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BookmarkIcon" Property="Opacity" Value="0.7" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

    </Grid>
</UserControl>
