<UserControl
    x:Class="YoutubeApplication.Components.SegmentedComponent.SegmentedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:YoutubeApplication.Components.SegmentedComponent"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Padding="8,0,0,4"
            FontWeight="SemiBold"
            Style="{StaticResource MaterialDesignBody1TextBlock}"
            Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        <ListBox
            Grid.Row="1"
            ItemsSource="{Binding Options, RelativeSource={RelativeSource AncestorType=UserControl}}"
            SelectedItem="{Binding Option, RelativeSource={RelativeSource AncestorType=UserControl}}"
            SelectionMode="Single"
            Style="{StaticResource MaterialDesignFilterChipPrimaryListBox}">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>

</UserControl>
