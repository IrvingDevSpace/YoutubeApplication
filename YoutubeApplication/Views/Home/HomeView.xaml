<UserControl x:Class="YoutubeApplication.Views.Home.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:YoutubeApplication.Views.Home"
             xmlns:search="clr-namespace:YoutubeApplication.Components.SearchBarComponent"
             xmlns:filter="clr-namespace:YoutubeApplication.Views.SearchFilter"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:helpers="clr-namespace:YoutubeApplication.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="10"
                        HorizontalAlignment="Center">

                <search:SearchBarView Keyword="{Binding Keyword}"
                                      IsSearching="{Binding IsLoading}"
                                      OnSearchCommand="{Binding OnSearchCommand}"
                                      Width="400" />

                <Button Margin="10,0,0,0"
                        Content="篩選"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding OpenSearchFilterCommand}" />
            </StackPanel>

            <Frame  Grid.Row="1"
                    x:Name="frame">
            </Frame>
        </Grid>

        <materialDesign:DialogHost IsOpen="{Binding IsSearchFilterOpen}"
                                   CloseOnClickAway="True">
            <materialDesign:DialogHost.DialogContent>
                <materialDesign:Card Width="420"
                                     Padding="20"
                                     UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp8"
                                     Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="FilterVariant"
                                                     VerticalAlignment="Center"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="搜尋篩選"
                                       Margin="10,0,0,0"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <filter:SearchFilterView Grid.Row="1"
                                                 OnSubmit="{Binding DataContext.OnSubmitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 OnClose="{Binding DataContext.CloseSearchFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </Grid>
                </materialDesign:Card>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>
