<UserControl
    x:Class="YoutubeApplication.Components.VideoCardComponent.VideoCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:YoutubeApplication.Components.VideoCardComponent"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <materialDesign:Card
        materialDesign:ElevationAssist.Elevation="Dp2"
        Background="{DynamicResource MaterialDesignPaper}"
        UniformCornerRadius="12">

        <Button
            Height="Auto"
            Padding="0"
            Command="{Binding ClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding VideoCard, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Foreground="{DynamicResource MaterialDesignBody}"
            Style="{StaticResource MaterialDesignFlatButton}">

            <Border Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,4"
                        ClipToBounds="True"
                        CornerRadius="8">
                        <Grid>
                            <Image
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="{Binding VideoCard.ImgSrc, TargetNullValue={x:Null}, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Stretch="UniformToFill" />

                            <!--<Border Background="#CC000000"
                                    CornerRadius="4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Padding="4,2"
                                    Margin="8">
                                <TextBlock Text="10:24"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Medium" />
                            </Border>-->
                        </Grid>
                    </Border>

                    <TextBlock
                        Grid.Row="1"
                        MaxHeight="50"
                        HorizontalAlignment="Left"
                        FontWeight="SemiBold"
                        Style="{StaticResource MaterialDesignBody1TextBlock}"
                        Text="{Binding VideoCard.Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />

                    <StackPanel Grid.Row="2" HorizontalAlignment="Left">
                        <TextBlock
                            FontSize="13"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="{Binding VideoCard.ChannelName, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{DynamicResource MaterialDesignBodyLight}"
                            Text="{Binding VideoCard.ViewSummary, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Button>
    </materialDesign:Card>
</UserControl>
