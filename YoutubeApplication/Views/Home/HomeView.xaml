<UserControl
    x:Class="YoutubeApplication.Views.Home.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:filter="clr-namespace:YoutubeApplication.Views.SearchFilter"
    xmlns:helpers="clr-namespace:YoutubeApplication.Helpers"
    xmlns:local="clr-namespace:YoutubeApplication.Views.Home"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:search="clr-namespace:YoutubeApplication.Components.SearchBarComponent"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                Margin="10"
                HorizontalAlignment="Center"
                Orientation="Horizontal">

                <search:SearchBarView
                    Width="400"
                    IsSearching="{Binding IsLoading}"
                    Keyword="{Binding Keyword}"
                    OnSearchCommand="{Binding OnSearchCommand}" />

                <Button
                    Margin="10,0,0,0"
                    Command="{Binding OpenSearchFilterCommand}"
                    Content="篩選"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>

            <Frame
                x:Name="frame"
                Grid.Row="1"
                Grid.ColumnSpan="3" />

            <Button
                Grid.Row="0"
                Grid.Column="2"
                Width="24"
                Height="24"
                Margin="0,0,12,0"
                Padding="0"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding OpenStudioCmd}">

                <Ellipse Width="24" Height="24">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding ChannelImageUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}" />
                    </Ellipse.Fill>
                </Ellipse>

            </Button>
        </Grid>

        <materialDesign:DialogHost IsOpen="{Binding IsSearchFilterOpen}">
            <materialDesign:DialogHost.DialogContent>
                <materialDesign:Card
                    Padding="20"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Background="{DynamicResource MaterialDesignPaper}"
                    UniformCornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel
                            Grid.Row="0"
                            Margin="0,0,0,16"
                            Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource PrimaryHueMidBrush}"
                                Kind="FilterVariant" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Style="{StaticResource MaterialDesignBody1TextBlock}"
                                Text="搜尋篩選" />
                        </StackPanel>

                        <filter:SearchFilterView
                            Grid.Row="1"
                            OnClose="{Binding DataContext.CloseSearchFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            OnSubmit="{Binding DataContext.OnSubmitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </Grid>
                </materialDesign:Card>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>
    </Grid>
</UserControl>
