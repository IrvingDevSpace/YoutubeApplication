<Page
    x:Class="YoutubeApplication.Pages.VideoSearchPage.VideoSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:YoutubeApplication.Pages.VideoSearchPage"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pagination="clr-namespace:YoutubeApplication.Components.PaginationComponent"
    xmlns:video="clr-namespace:YoutubeApplication.Components.VideoCardComponent"
    Title="VideoSearchPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ListBox
            Grid.Row="0"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding VideoCards}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid VerticalAlignment="Top" Columns="5" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Style.Resources>
                        <SolidColorBrush x:Key="MaterialDesignSelection" Color="Transparent" />
                    </Style.Resources>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <video:VideoCardView
                        Margin="4"
                        OnClickCommand="{Binding DataContext.OnVideoCardClickCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                        VideoCard="{Binding}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="0">

            <ProgressBar
                Width="200"
                Height="20"
                Margin="0,20,0,0"
                VerticalAlignment="Center"
                IsIndeterminate="True">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Hidden" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </Grid>

        <pagination:PaginationView
            Grid.Row="1"
            CurrentPage="{Binding CurrentPage}"
            OnPageChangeCommand="{Binding OnPageChangeCommand}"
            OnPageSizeChangeCommand="{Binding OnPageSizeChangeCommand}"
            PageSize="{Binding PageSize}"
            Total="{Binding Total}" />
    </Grid>
</Page>
