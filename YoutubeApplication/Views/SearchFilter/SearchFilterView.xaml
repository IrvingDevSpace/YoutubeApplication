<UserControl x:Class="YoutubeApplication.Views.SearchFilter.SearchFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:YoutubeApplication.Views.SearchFilter"
             xmlns:segmented="clr-namespace:YoutubeApplication.Components.SegmentedComponent"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <segmented:SegmentedView Grid.Column="0"
                                         Title="類型"
                                         Options="{Binding TypeOptions}"
                                         Option="{Binding SelectedType}" />
                <segmented:SegmentedView Grid.Column="1"
                                         Title="片長"
                                         Options="{Binding DurationOptions}"
                                         Option="{Binding SelectedDuration}" />
                <segmented:SegmentedView Grid.Column="2"
                                         Title="上傳日期"
                                         Options="{Binding DateOptions}"
                                         Option="{Binding SelectedDate}" />
                <segmented:SegmentedView Grid.Column="3"
                                         Title="優先順序"
                                         Options="{Binding OrderOptions}"
                                         Option="{Binding SelectedOrder}" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="套用"
                        Padding="12,6"
                        Margin="0,0,8,0"
                        Command="{Binding OnSubmitCommand}" />
                <Button Content="取消"
                        Padding="12,6"
                        Command="{Binding OnCloseCommand}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>

</UserControl>
